{
  "routes": [
    {
      "src": "^/favicon\\.ico$",
      "dest": "/favicon.ico"
    },
    {
      "src": "^/favicon\\.svg$",
      "dest": "/favicon.svg"
    },
    {
      "src": "^/favicon\\.png$",
      "dest": "/favicon.png"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/api-turnos(.*)",
      "dest": "/index.html"
    },
    {
      "src": "^/index\\.html$",
      "dest": "/index.html"
    },
    {
      "src": "^/$",
      "dest": "/api/basic-auth"
    },
    {
      "src": "/(.*)",
      "dest": "/api/basic-auth"
    }
  ]
}