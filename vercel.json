{
  "routes": [
    {
      "src": "^/api-turnos/?$",
      "dest": "/api-turnos"
    },
    {
      "src": "^/api-turnos/(.*)",
      "dest": "/api-turnos/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/basic-auth"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}