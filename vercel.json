{
  "routes": [
    {
      "src": "^/api-turnos(.*)",
      "dest": "/api-turnos$1"
    },
    {
      "src": "^/index\\.html$",
      "dest": "/index.html"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/basic-auth"
    }
  ]
}